{
  "name": "portfolio-site",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --env-file-if-exists=.env --watch-path=.env --watch server/server.js",
    "build": "vite build",
    "start": "node --env-file-if-exists=.env server/server.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "nodemailer": "^8.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.3"
  }
}
